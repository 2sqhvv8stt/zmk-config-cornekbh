/*
 * Corne wireless (42-key, 6-column foostan) — dongle / central shield
 * for the Prospector display.
 *
 * IMPORTANT: This shield must define the EXACT SAME set of physical layouts
 * and matrix transforms as the real keyboard halves. The built-in ZMK `corne`
 * shield defines BOTH a 5-column and a 6-column layout plus a position map.
 * If the dongle only defines one of them, ZMK renumbers key positions and the
 * keymap comes out shifted. That was the bug in the previous attempt (only the
 * 6-column layout was included).
 *
 * The blocks below are copied verbatim from ZMK's app/boards/shields/corne/
 * corne.dtsi (v0.3), minus the real kscan / OLED, with a mock kscan added.
 */

#include <dt-bindings/zmk/matrix_transform.h>

#include <layouts/foostan/corne/5column.dtsi>
