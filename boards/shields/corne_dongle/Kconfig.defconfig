if SHIELD_CORNE_DONGLE

config ZMK_KEYBOARD_NAME
    default "CorneKBH"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT
    default y

# left + right halves
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

# peripherals (2) + BT profiles (5)
config BT_MAX_CONN
    default 7

config BT_MAX_PAIRED
    default 7

endif
